# Public dashboard data source.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin surface uses the service role key so it can read PII (lead
# emails, contact names, intent details) and RLS-restricted columns
# without the public anon-key fallback.
SUPABASE_SECRET_KEY=

# /admin login credentials. Pick a long random password (24+ chars).
# Successful logins receive a signed, HttpOnly session cookie. A separate
# 32+ character session secret is recommended; when omitted, ADMIN_PASS is
# used to sign sessions for backwards-compatible deployments. Rotating either
# secret invalidates existing sessions. If ADMIN_USER or ADMIN_PASS is missing,
# the admin surface returns 503 so misconfiguration never looks like "no data".
ADMIN_USER=
ADMIN_PASS=
ADMIN_SESSION_SECRET=

# Optional. Defaults to http://52.91.135.79:8000. Used by the admin
# "New request" form to proxy POST /fulfillment/request without exposing
# SUPABASE_SECRET_KEY to the browser.
FULFILLMENT_GATEWAY_URL=http://52.91.135.79:8000

# Optional. Base URL of the research-lab gateway that serves
# GET /research-lab/benchmarks/public/scoring-status. When set, the Research Lab
# hero shows live "X/20 ICPs" progress while today's baseline benchmark is
# scoring. When unset, the dashboard falls back to deriving the scoring state
# from the latest published benchmark date (no per-ICP progress count).
RESEARCH_LAB_GATEWAY_URL=

# Durable Research Lab operations alerts. Install the Supabase migrations before
# enabling the monitor. Validators can be registered from Admin → Alerts; this
# optional env list is useful for immutable bootstrap coverage. Either registry
# is what lets the evaluator detect a completely missing validator.
RESEARCH_LAB_ALERT_MONITOR_ENABLED=false
RESEARCH_LAB_ALERT_MONITOR_INTERVAL_MS=60000
OPS_MONITORED_VALIDATOR_HOTKEYS=

# Optional comma-separated allowlist of canonical signal names. Leave blank to
# evaluate every signal. Invalid names stop the monitor and are recorded in its
# durable heartbeat instead of silently weakening coverage.
RESEARCH_LAB_ALERT_SIGNALS=

# Operator dashboard link included in every notification. Required whenever an
# email or Discord channel is configured.
RESEARCH_LAB_ALERT_DASHBOARD_URL=https://subnet71.com/admin
RESEARCH_LAB_ALERT_MINIMUM_SEVERITY=warning
RESEARCH_LAB_ALERT_TIMEOUT_MS=10000

# Discord is enabled when a webhook URL is present.
RESEARCH_LAB_ALERT_DISCORD_WEBHOOK_URL=
RESEARCH_LAB_ALERT_DISCORD_USERNAME=Leadpoet Bug Watch

# One-shot benchmark completion and improvement-analysis events. The benchmark
# route reuses Bug Watch above; completed Sol analyses use the Lab Chat webhook.
RESEARCH_LAB_EVENT_MONITOR_ENABLED=false
RESEARCH_LAB_EVENT_MONITOR_INTERVAL_MS=60000
RESEARCH_LAB_IMPROVEMENT_DISCORD_WEBHOOK_URL=
RESEARCH_LAB_IMPROVEMENT_DISCORD_USERNAME=Leadpoet Lab Watch
RESEARCH_LAB_IMPROVEMENT_ANALYSIS_TIMEOUT_MS=600000
OPENAI_API_KEY=

# Email is sent through Resend's HTTPS API when all required values are present.
# Multiple recipients may be comma-separated.
RESEARCH_LAB_ALERT_RESEND_API_KEY=
RESEARCH_LAB_ALERT_EMAIL_FROM=
RESEARCH_LAB_ALERT_EMAIL_TO=
RESEARCH_LAB_ALERT_EMAIL_REPLY_TO=

# Optional but recommended for /admin/requests/new. Enables "Parse with AI"
# so operators can paste a raw ICP and get a structured editable draft.
OPENROUTER_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Optional: used to compose absolute OG image URLs in production.
NEXT_PUBLIC_SITE_URL=https://subnet71.com

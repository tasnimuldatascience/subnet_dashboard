# Public dashboard data source.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin surface uses the service role key so it can read PII (lead
# emails, contact names, intent details) and RLS-restricted columns
# without the public anon-key fallback.
SUPABASE_SECRET_KEY=

# /admin Basic Auth credentials. Pick a long random password (24+
# chars). The middleware compares with constant-time equality.
# If either is missing, the admin surface returns 503 so misconfig
# never looks like "no data".
ADMIN_USER=
ADMIN_PASS=

# Optional. Defaults to http://52.91.135.79:8000. Used by the admin
# "New request" form to proxy POST /fulfillment/request without exposing
# SUPABASE_SECRET_KEY to the browser.
FULFILLMENT_GATEWAY_URL=http://52.91.135.79:8000

# Optional. Base URL of the research-lab gateway that serves
# GET /research-lab/benchmarks/public/scoring-status. When set, the Research Lab
# hero shows live "X/20 ICPs" progress while today's baseline benchmark is
# scoring. When unset, the dashboard falls back to deriving the scoring state
# from the latest published benchmark date (no per-ICP progress count).
RESEARCH_LAB_GATEWAY_URL=

# Optional but recommended for /admin/requests/new. Enables "Parse with AI"
# so operators can paste a raw ICP and get a structured editable draft.
OPENROUTER_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Optional: used to compose absolute OG image URLs in production.
NEXT_PUBLIC_SITE_URL=https://subnet71.com
